# EditorConfig: https://editorconfig.org
root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{c,h}]
indent_style = tab
indent_size = 4

[*.{lua,sh,py}]
indent_style = space
indent_size = 4

[*.{xml,nix}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[{meson.build,meson_options.txt}]
indent_style = space
indent_size = 2
